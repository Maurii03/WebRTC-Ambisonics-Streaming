# AmbiRTC MCU — environment template. Copy to mcu/.env and fill in, OR just put
# the credentials in the repo-root ../.env (the MCU reads ./.env then ../.env).
#
# Cloudflare Realtime TURN key — the MCU mints short-lived ICE/TURN credentials
# from these and serves them to BROWSERS at /api/turn-credentials (the SAME key
# the Node stack uses, server.js /api/turn-credentials). The MCU itself never
# relays: it has a public IP and is reached directly; TURN is only the fallback
# for a client behind a restrictive NAT (that client's own relay). Create a key in
# the Cloudflare dashboard: Realtime -> TURN -> Create. Optional but recommended.
CF_TURN_KEY_ID=
CF_API_TOKEN=

# Public IP of the server — IMPORTANT on a cloud/public host: advertised as the
# MCU's host candidate (NAT1To1) so clients connect DIRECTLY (no relay, no extra
# latency). Without it, behind 1:1 NAT the MCU only gathers its private IP and
# every session is forced onto TURN. Leave empty for localhost/LAN.
# MCU_PUBLIC_IP=203.0.113.5

# Optional server tuning (flags override these): all have sensible defaults.
# MCU_ADDR=:8080
# MCU_FRAME_SIZE=960
# MCU_ENCODE_WORKERS=4
# MCU_VAD_THRESHOLD=0
# MCU_STUN_URL=stun:stun.cloudflare.com:3478   # empty to disable STUN on the MCU
# MCU_ENV_FILE=/abs/path/to/.env               # override which .env file is loaded
